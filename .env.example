# AI Usage Dashboard Configuration

# 데이터베이스
DB_PATH=./data/usage.db

# HTTP 서버
SERVER_PORT=8080

# 데이터 수집 주기 (초)
COLLECTION_INTERVAL=300

# Provider credential 경로 재정의 (기본값 사용 시 주석 처리)
# 각 provider는 로컬 앱의 OAuth 토큰을 자동으로 탐색합니다.

# Claude: ~/.claude/.credentials.json (claude CLI 로그인 후 생성)
# CLAUDE_CRED_PATH=~/.claude/.credentials.json

# Gemini: ~/.gemini/oauth_creds.json (gemini CLI 로그인 후 생성)
# GEMINI_CRED_PATH=~/.gemini/oauth_creds.json

# Cursor: SQLite DB 경로 (미설정 시 OS별 표준 경로 자동 탐색)
# CURSOR_DB_PATH=~/.cursor/User/globalStorage/storage.vscdb
